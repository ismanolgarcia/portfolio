---
interface Props {
  title: string;
  href: string;
  tipo: string;
}

const { href, title, tipo } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class=`${tipo == 'fill' ?  
  'bg-stone-950 text-stone-50 hover:bg-white hover:text-stone-950' : 
  'hover:bg-stone-950 hover:text-stone-50' } 
  font-bold py-2 px-5 border-2 border-stone-950 text-lg`
>
  {title}
</a>
